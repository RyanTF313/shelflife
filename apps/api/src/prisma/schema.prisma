generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URL has been moved out of the schema. Configure the
  // datasource connection in prisma.config.ts as described in
  // https://pris.ly/d/config-datasource
}

model User {
  id String @id @default(uuid())
  email        String    @unique
  passwordHash String
  products     Product[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
model Product {
  id String @id @default(uuid())
  name        String
  description String
  image       String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  videos      Video[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Video {
  id           String   @id @default(uuid())
  title        String
  videoUrl     String
  thumbnailUrl String?
  publicId     String   @unique
  duration     Int?
  width        Int?
  height       Int?
  views        Int      @default(0)
  clicks       Int      @default(0)
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  events       VideoEvent[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VideoEvent {
  id String @id @default(uuid())
  type      EventType
  videoId   String
  video     Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum EventType {
  VIEW
  CLICK
}